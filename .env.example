# Database
DATABASE_URL=postgresql://blog:blogpass@localhost:5432/blogdb

# NextAuth — IMPORTANT: Change NEXTAUTH_SECRET to a random string in production!
NEXTAUTH_SECRET=your-secret-here-MUST-CHANGE-IN-PRODUCTION
NEXTAUTH_URL=http://localhost:3000

# SMTP (Email) — Configure for invite system
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@demo.polardev.org
