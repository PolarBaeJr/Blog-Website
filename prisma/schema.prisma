// This is a minimal Prisma schema for initial project setup.
// The full schema with all models will be created by task-002 (Prisma Schema and Database Setup).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Placeholder model to allow Prisma Client generation.
// This will be replaced with the full schema in task-002.
model SiteSettings {
  id              String   @id @default("singleton")
  blogTitle       String   @default("My Blog")
  blogDescription String   @default("A simple blog")
  footerText      String   @default("")
  updatedAt       DateTime @updatedAt
}
