# Dependencies (will be installed fresh in container)
node_modules

# Next.js build output (will be rebuilt in container)
.next

# Git history (not needed in image)
.git
.gitignore

# Environment files (secrets must not be baked into image)
.env
.env.local
.env.*.local

# Uploaded files (mounted as volume at runtime)
public/uploads/*
!public/uploads/.gitkeep

# IDE and OS files
.vscode
.idea
.DS_Store
Thumbs.db

# Documentation (not needed in production image)
README.md
docs/

# Conductor / orchestration files
.conductor/
.codex/
.codex-reviews/
.claude/

# TypeScript build info
*.tsbuildinfo
