# Dependencies
node_modules/

# Next.js
.next/
out/

# Environment files (all variants)
.env
.env.*
!.env.example

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Prisma
prisma/*.db

# Uploads (keep the directory, ignore contents)
public/uploads/*
!public/uploads/.gitkeep

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Backups
backups/
*.sql
*.sql.gz
# But keep Prisma migration SQL files (they must be version-controlled)
!prisma/migrations/**/*.sql

# Secrets and keys
*.pem
*.key
secrets/

# Claude Code Conductor (C3) — generated state, not source code
.conductor/
.codex-reviews/
.codex/
.claude/
